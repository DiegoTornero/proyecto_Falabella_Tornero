# ─── Core Backend — Variables de Entorno Seguras ────────────────────────────────
# INSTRUCCIÓN: Copia este archivo como `.env` y completa los valores reales.
# NUNCA subas el archivo .env a git (ya está en .gitignore).

# Base de datos PostgreSQL
DATABASE_URL=postgresql://postgres:TU_PASSWORD_REAL@localhost:5432/falabella_db

# JWT Core — Cambia esta clave por una segura (mínimo 32 caracteres aleatorios)
SECRET_KEY=cambia_esto_por_una_clave_aleatoria_de_64_caracteres_minimo_aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Entorno (development | production)
ENV=development
